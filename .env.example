# Base de données
DATABASE_URL="postgresql://postgres:password@localhost:5432/inventaire_intelligent"

# JWT
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="7d"

# Chiffrement AES-256
ENCRYPTION_KEY="change-me-32-chars-exactly-here!!"

# Application
NODE_ENV="development"
PORT=3001
FRONTEND_URL="http://localhost:3000"

# Mapbox (optionnel, Leaflet/OSM utilisé par défaut)
NEXT_PUBLIC_MAPBOX_TOKEN=""

# Upload photos
UPLOAD_DIR="uploads"
MAX_FILE_SIZE_MB=10
